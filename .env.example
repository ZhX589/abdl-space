# ABDL Space 环境变量

# JWT 密钥（生产环境必填，使用随机字符串）
JWT_SECRET=your-super-secret-jwt-key-change-me

# Cloudflare D1 数据库名称
D1_DATABASE_NAME=abdl-space-db

# AI 推荐服务（v0.4.0 规划）
# AI_API_KEY=your-ai-service-api-key
# AI_API_URL=https://api.deepseek.com/v1

# Cloudflare R2 存储（v0.6.0 规划）
# R2_BUCKET_NAME=abdl-space-assets
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=

# 腾讯云 SES 邮件服务
TENCENT_SECRET_ID=your-tencent-secret-id
TENCENT_SECRET_KEY=your-tencent-secret-key
SES_FROM_EMAIL=ABDL Space <admin@abdl-space.top>
SES_TEMPLATE_ID=184446
SES_REGION=ap-guangzhou

# NewBabyWorld OAuth
# NBW_CLIENT_ID=
# NBW_CLIENT_SECRET=
# NBW_REDIRECT_URI=https://abdl-space.top/auth/nbw/callback
# NBW_CLIENT_ID_MOBILE=
# NBW_CLIENT_SECRET_MOBILE=
# NBW_REDIRECT_URI_MOBILE=https://m.abdl-space.top/auth/nbw/callback

# Turnstile 人机验证
# TURNSTILE_SITE_KEY=
# TURNSTILE_SECRET_KEY=

# DeepSeek AI 推荐
# DEEPSEEK_API_KEY=

# 开发环境使用 .dev.vars（已 gitignore），生产环境在 Cloudflare Dashboard 设置
