# ABDL Space Wiki 环境变量

# JWT 密钥（生产环境必填，使用随机字符串）
JWT_SECRET=your-super-secret-jwt-key-change-me

# Cloudflare D1 数据库名称
D1_DATABASE_NAME=abdl-space-db

# Cloudflare R2 存储（如需文件上传）
# R2_BUCKET_NAME=abdl-space-assets
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=

# 开发环境使用 .dev.vars（已 gitignore），生产环境在 Cloudflare Dashboard 设置
